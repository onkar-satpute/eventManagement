# GEMINI_API_KEY: Required for Gemini AI features.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# JWT_SECRET: Secret key for signing JSON Web Tokens (JWT).
JWT_SECRET="YOUR_JWT_SECRET_HERE"

# APP_URL: The URL where this app is hosted (used for absolute self-links).
APP_URL="http://localhost:3000"

# DB_PATH: Path to the SQLite database file (e.g., events.db).
DB_PATH="events.db"

# UPLOADS_DIR: Directory where uploaded files (like event rules PDF) are saved.
UPLOADS_DIR="public/uploads/rules"

# PORT: The port the Express server listens on.
PORT=3000

# DISABLE_HMR: Set to "true" to disable Vite Hot Module Replacement.
# Normally set via start scripts; manually set this if needed.
DISABLE_HMR="true"
ADMIN_MOBILE="admin-mobile"
ADMIN_PASSWORD="password"
